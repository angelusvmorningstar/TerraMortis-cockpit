# Cockpit connects ONLY to local databases. NEVER put production credentials here.
# Connection isolation is the Phase 1 safety mechanism: the tool holds no production
# write credentials, so it cannot reach or alter live data. Keep these local-only.
#
# Copy this file to .env and adjust host/port for your local MongoDB if needed —
# but both URIs MUST stay local.

# Local sandbox (read-only projection source) — seeded from a prod snapshot; see Story 1.3.
SANDBOX_URI=mongodb://127.0.0.1:27017/tm_suite_dev

# Local ST-authored reference data (glossary, channel rules, codified rules).
CHRONICLE_URI=mongodb://127.0.0.1:27017/tm_chronicle
